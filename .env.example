# ============================================================
# VOILECTIA — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# Base de données MySQL — Hostinger
# Récupérez ces infos dans : Hosting → Gérer → MySQL → Bases de données
# Format : mysql://UTILISATEUR:MOT_DE_PASSE@localhost:3306/NOM_BASE
DATABASE_URL="mysql://u123456789_voilectia:VOTRE_MDP@127.0.0.1:3306/u123456789_voilectia"

# NextAuth — Secret aléatoire (générer avec: openssl rand -base64 32)
AUTH_SECRET="CHANGE_ME_GENERATE_A_RANDOM_SECRET"

# URL publique du site (sans slash final)
NEXTAUTH_URL="http://localhost:3000"

# Discord — Lien d'invitation du serveur
NEXT_PUBLIC_DISCORD_URL="https://discord.gg/VOTRE_CODE"

# Discord — Lien du bot ou webhook pour les statistiques (optionnel)
DISCORD_BOT_TOKEN=""
DISCORD_GUILD_ID=""

# IP du serveur Eco (pour les stats de connexion)
ECO_SERVER_IP="votre-serveur.fr"
ECO_SERVER_PORT="3000"

# Email de contact (affiché sur la page Contact)
CONTACT_EMAIL="contact@voilectia.fr"

# Tipeee (optionnel — pour la page Soutenir)
NEXT_PUBLIC_TIPEEE_URL="https://fr.tipeee.com/voilectia"

# Dossier d'upload (relatif à /public)
UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE_MB="5"

# Environnement
NODE_ENV="development"
