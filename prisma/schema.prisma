// ============================================================
// VOILECTIA — Schéma Prisma (MySQL — Hostinger Web Apps)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Authentification ────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("EDITOR") // SUPER_ADMIN | ADMIN | EDITOR | PLAYER
  avatar        String?
  // Rang staff personnalisé (optionnel — remplace le rôle si défini)
  rankId        String?
  rank          Rank?     @relation(fields: [rankId], references: [id])
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  articles      Article[]
  changelogs    Changelog[]
  guides        Guide[]
  events        Event[]
  adminSessions AdminSession[]

  @@map("users")
}

// ─── Sessions admin (tokens hashés, expiration) ──────────────

model AdminSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique            // SHA-256 du token de session (jamais le token brut)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
  @@map("admin_sessions")
}

// ─── Rangs staff (permissions) ────────────────────────────

model Rank {
  id          String   @id @default(cuid())
  name        String   @unique        // "Modérateur", "Admin", "Super Admin"
  color       String   @default("#3A7A52")
  badge       String?                 // emoji affiché devant le nom
  level       Int      @default(0)   // hiérarchie : 0=viewer, 1=éditeur, 2=modo, 3=admin, 4=super
  // Permissions
  canPublish         Boolean @default(false)
  canManageArticles  Boolean @default(false)
  canManageStaff     Boolean @default(false)
  canManageRanks     Boolean @default(false)
  canManageUsers     Boolean @default(false)
  isStaff            Boolean @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]

  @@map("ranks")
}

// ─── Articles / Actualités ────────────────────────────────────

model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String? @db.Text
  content     String @db.Text
  coverImage  String?
  category    String    @default("news") // news | announcement | update
  published   Boolean   @default(false)
  pinned      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  authorId    String
  author      User      @relation(fields: [authorId], references: [id])

  metaTitle   String?
  metaDesc    String?
  ogImage     String?

  @@map("articles")
}

// ─── Changelog ────────────────────────────────────────────────

model Changelog {
  id          String    @id @default(cuid())
  version     String
  title       String
  content     String @db.Text
  season      String    @default("S1")
  type        String    @default("update") // update | hotfix | major | content
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  authorId    String
  author      User      @relation(fields: [authorId], references: [id])

  @@map("changelogs")
}

// ─── Guides ──────────────────────────────────────────────────

model Guide {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String? @db.Text
  content     String @db.Text
  category    String    @default("debutant") // debutant | metier | economie | ecoGnome | ville
  coverImage  String?
  order       Int       @default(0)
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  authorId    String
  author      User      @relation(fields: [authorId], references: [id])

  metaTitle   String?
  metaDesc    String?

  @@map("guides")
}

// ─── Categories de guides (dynamiques) ───────────────────────

model GuideCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("guide_categories")
}

// ─── Événements ───────────────────────────────────────────────

model Event {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String
  content     String? @db.Text
  coverImage  String?
  startDate   DateTime
  endDate     DateTime?
  location    String?   // "In-game" | "Discord" | "Mixte"
  type        String    @default("community") // community | build | economy | special
  status      String    @default("upcoming") // upcoming | ongoing | past
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  authorId    String
  author      User      @relation(fields: [authorId], references: [id])

  images      EventImage[]

  @@map("events")
}

model EventImage {
  id       String @id @default(cuid())
  url      String
  alt      String?
  order    Int    @default(0)
  eventId  String
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_images")
}

// ─── Staff ────────────────────────────────────────────────────

model StaffMember {
  id          String   @id @default(cuid())
  name        String
  role        String   // "Fondateur" | "Admin" | "Modérateur" | "Helper" | etc.
  description String?
  avatar      String?
  discordId   String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("staff_members")
}

// ─── Règlement ────────────────────────────────────────────────

model Rule {
  id          String   @id @default(cuid())
  categoryId  String
  category    RuleCategory @relation(fields: [categoryId], references: [id])
  title       String
  content     String @db.Text
  order       Int      @default(0)
  severity    String   @default("info") // info | warning | danger
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("rules")
}

model RuleCategory {
  id        String   @id @default(cuid())
  name      String
  icon      String?
  order     Int      @default(0)
  rules     Rule[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rule_categories")
}

// ─── FAQ ──────────────────────────────────────────────────────

model FaqItem {
  id         String   @id @default(cuid())
  question   String
  answer     String
  categoryId String
  category   FaqCategory @relation(fields: [categoryId], references: [id])
  order      Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("faq_items")
}

model FaqCategory {
  id        String    @id @default(cuid())
  name      String
  icon      String?
  order     Int       @default(0)
  items     FaqItem[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("faq_categories")
}

// ─── Médias ───────────────────────────────────────────────────

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  alt       String?
  folder    String   @default("general")
  createdAt DateTime @default(now())

  @@map("medias")
}

// ─── Pages personnalisées ─────────────────────────────────────

model CustomPage {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  icon        String?
  showInNav   Boolean  @default(false)
  navSection  String?
  published   Boolean  @default(false)
  order       Int      @default(0)
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("custom_pages")
}

// ─── Navigation personnalisée ─────────────────────────────────

model NavItem {
  id        String   @id @default(cuid())
  label     String
  href      String   @default("")
  icon      String?
  section   String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  external  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nav_items")
}

// ─── Votes Top-Serveur ────────────────────────────────────────

model TopServeurVote {
  id         String   @id @default(cuid())
  voterToken String
  createdAt  DateTime @default(now())

  @@map("top_serveur_votes")
}

// ─── Paramètres du site ───────────────────────────────────────

model SiteSettings {
  id                 String    @id @default("singleton")
  siteName           String    @default("Voilectia ECO")
  siteDescription    String?
  discordUrl         String?
  serverIp           String?
  serverPort         String?
  tipeeeUrl          String?
  contactEmail       String?
  season             String    @default("S1")
  maintenanceMode    Boolean   @default(false)
  heroTitle          String?
  heroSubtitle       String?
  ogImage            String?
  // Maintenance avancée
  maintenanceActive  Boolean   @default(false)
  maintenanceTitle   String    @default("Saison 2 — Bientôt disponible")
  maintenanceMessage String    @default("Le serveur se prépare pour une nouvelle aventure.")
  launchDate         DateTime?
  allowedSections    String    @default("[\"forum\",\"tutoriels\",\"top-serveur\"]") @db.Text
  // Carte Eco
  ecoMapEnabled      Boolean   @default(false)
  ecoMapUrl          String    @default("")
  ecoMapTitle        String    @default("Carte du monde")
  // Liens & config
  siteDiscordUrl     String?
  siteServerIp       String?
  updatedBy          String?
  // Contenu éditable
  announcementEnabled Boolean  @default(false)
  announcementText    String?  @db.Text
  homeHeroTitle       String?
  homeHeroSubtitle    String?  @db.Text

  @@map("site_settings")
}

// Tutoriels

model Tutorial {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  excerpt    String?  @db.Text
  content    String   @db.Text
  category   String   @default("debutant")
  coverImage String?
  featured   Boolean  @default(false)
  order      Int      @default(0)
  published  Boolean  @default(false)
  views      Int      @default(0)
  authorName String?
  metaTitle  String?
  metaDesc   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("tutorials")
}

// ─── Contenu éditable des pages statiques ────────────────────

model PageContent {
  id        String   @id @default(cuid())
  page      String                         // slug de la page : "presentation", "economie"…
  key       String                         // identifiant du bloc : "hero_title", "intro", "section_1"…
  value     String   @db.LongText
  type      String   @default("text")      // "text" | "html" | "markdown"
  label     String?                        // libellé affiché dans l'admin
  updatedAt DateTime @updatedAt

  @@unique([page, key])
  @@map("page_contents")
}

// ─── Configuration du serveur Eco ────────────────────────────

model ServerConfig {
  id          String   @id @default("singleton")
  worldSize   String   @default("4km")        // "4km" | "8km" | "12km"
  difficulty  String   @default("Normal")     // "Easy" | "Normal" | "Hard"
  xpRate      String   @default("x1")
  specialties Int      @default(5)            // nb de spécialités par joueur
  currency    String   @default("VLC")
  season      String   @default("S1")
  status      String   @default("preparation") // preparation | open | closed | maintenance
  serverIp    String?
  serverPort  String?
  ecoVersion  String?                           // ex : "0.13.x"
  maxPlayers  Int?
  modpack     String?
  discordUrl     String?
  topServeurUrl  String?
  description String?  @db.Text
  startDate   DateTime?
  endDate     DateTime?
  updatedAt   DateTime @updatedAt

  progressions JobProgression[]

  @@map("server_config")
}

// ─── Configuration serveur — blocs flexibles (groupes + lignes) ──

model ServerConfigGroup {
  id        String   @id @default(cuid())
  title     String
  icon      String?
  order     Int      @default(0)
  items     ServerConfigItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("server_config_groups")
}

model ServerConfigItem {
  id          String   @id @default(cuid())
  groupId     String
  group       ServerConfigGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  label       String
  value       String
  description String?  @db.Text
  icon        String?
  order       Int      @default(0)
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([groupId])
  @@map("server_config_items")
}

model JobProgression {
  id             String       @id @default(cuid())
  configId       String
  config         ServerConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  jobName        String       // "Mécanique", "Industrie", "Pétrole", "Électronique"…
  unlockDay      Int          // Jour de déblocage
  description    String?
  icon           String?      // emoji
  color          String       @default("#3A7A52")
  order          Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("job_progressions")
}

// ─── Giveaways ────────────────────────────────────────────────

model Giveaway {
  id          String          @id @default(cuid())
  title       String
  description String          @db.Text
  prize       String          // Quoi gagner
  image       String?
  endDate     DateTime
  published   Boolean         @default(false)
  ended       Boolean         @default(false)
  winnerId    String?
  winnerName  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  entries     GiveawayEntry[]

  @@map("giveaways")
}

model GiveawayEntry {
  id          String   @id @default(cuid())
  giveawayId  String
  giveaway    Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  playerName  String
  discordTag  String?
  email       String?
  createdAt   DateTime @default(now())

  @@unique([giveawayId, email])
  @@map("giveaway_entries")
}

// ─── Journal admin (AuditLog) ─────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  userName   String
  action     String   // "CREATE" | "UPDATE" | "DELETE" | "BAN" | "LOGIN"
  resource   String   // "article" | "user" | "city"...
  resourceId String?
  detail     String?  @db.Text
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
